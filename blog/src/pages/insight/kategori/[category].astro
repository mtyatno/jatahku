---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  return [
    { params: { category: 'tutorial' } },
    { params: { category: 'tips-keuangan' } },
    { params: { category: 'update-fitur' } },
  ];
}

const { category } = Astro.params;
const all = await getCollection('articles');
const articles = all
  .filter(a => a.data.category === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabel: Record<string, string> = {
  'tutorial': 'Tutorial',
  'tips-keuangan': 'Tips Keuangan',
  'update-fitur': 'Update Fitur',
};
const categoryColor: Record<string, string> = {
  'tutorial': '#0F6E56',
  'tips-keuangan': '#BA7517',
  'update-fitur': '#1D4ED8',
};
const label = categoryLabel[category] ?? category;
const color = categoryColor[category] ?? '#0F6E56';
---
<Base title={label} description={`Artikel kategori ${label} — Jatahku Insight`} activeCategory={category}>
  <style>
    .page-hero{padding:40px 24px 32px;background:var(--white);border-bottom:1px solid var(--border)}
    .container{max-width:1100px;margin:0 auto}
    .cat-title{font-family:var(--font-d);font-size:clamp(22px,3vw,32px);font-weight:700;letter-spacing:-.3px;margin-bottom:6px}
    .cat-count{font-size:14px;color:var(--text-t)}
    .section{padding:40px 24px 80px}
    .articles-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
    .card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-decoration:none;color:inherit;transition:all .2s;display:flex;flex-direction:column}
    .card:hover{border-color:#1D9E75;box-shadow:0 4px 16px rgba(15,110,86,.08)}
    .card-badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px}
    .card-title{font-family:var(--font-d);font-size:16px;font-weight:700;line-height:1.3;margin-bottom:8px}
    .card-desc{font-size:14px;color:var(--text-s);line-height:1.6;flex:1}
    .card-meta{margin-top:12px;font-size:12px;color:var(--text-t)}
    .empty{text-align:center;padding:80px 0;color:var(--text-t)}
  </style>

  <div class="page-hero">
    <div class="container">
      <a href="/insight" style="font-size:14px;color:var(--text-s);text-decoration:none;display:inline-block;margin-bottom:12px">← Semua Insight</a>
      <h1 class="cat-title" style={`color:${color}`}>{label}</h1>
      <p class="cat-count">{articles.length} artikel</p>
    </div>
  </div>

  <div class="section">
    <div class="container">
      {articles.length === 0 ? (
        <div class="empty">Belum ada artikel di kategori ini.</div>
      ) : (
        <div class="articles-list">
          {articles.map(article => (
            <a href={`/insight/${article.slug}`} class="card">
              <span class="card-badge" style={`background:${color}18;color:${color}`}>{label}</span>
              <h2 class="card-title">{article.data.title}</h2>
              <p class="card-desc">{article.data.description}</p>
              <div class="card-meta">
                {article.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Base>
